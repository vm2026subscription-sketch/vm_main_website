# ── Flask / App ──────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string
FLASK_ENV=development

# URL embedded in password-reset emails
# Local:    http://127.0.0.1:5001
# Production: https://vidyarthimitra.org
PUBLIC_BASE_URL=http://127.0.0.1:5001

# ── Gmail SMTP (login OTP + forgot-password emails) ──────────────────────────
#
# Setup (one-time):
#   1. Enable 2-Step Verification on your Google account
#      https://myaccount.google.com/signinoptions/two-step-verification
#   2. Create an App Password (Mail → Other → "Vidyarthi Mitra")
#      https://myaccount.google.com/apppasswords
#   3. Copy the 16-character password (no spaces) into SMTP_PASS below
#
# Do NOT use your normal Gmail password — Google blocks that for SMTP.
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM_EMAIL=your@gmail.com
SMTP_USE_TLS=1

# ── Password reset ───────────────────────────────────────────────────────────
PASSWORD_RESET_EXPIRY_SECONDS=1800

# ── Auth database (optional — local dev uses SQLite if unset) ────────────────
# DATABASE_URL=postgresql://...
# SUPABASE_POSTGRES_URL=postgresql://...
